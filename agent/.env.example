# Fixi Agent — Environment Variables
# Copy to .env and fill in values.
# NEVER commit .env with real values.

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=

# Optional: GitHub token for cloning private repos and creating PRs
GH_TOKEN=
# GITHUB_TOKEN=  # Alternative name (used by GitHub Actions automatically)

# Optional: Azure DevOps PAT for ADO repos and work items
AZURE_DEVOPS_PAT=
